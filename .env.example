# Telegram Stars — переменные окружения

# Обязательно для реальных платежей (только на сервере, не VITE_!)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Webhook (опционально, рекомендуется)
# После деплоя: https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://YOUR_APP.vercel.app/api/telegram/webhook&secret_token=YOUR_SECRET
TELEGRAM_WEBHOOK_SECRET=random_secret_string

# Supabase для хранения платежей (рекомендуется в production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Локальная разработка вне Telegram (только npm run dev)
VITE_STARS_DEV_MOCK=false
