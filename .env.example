# Telegram Stars — переменные окружения

# Токен бота от @BotFather (обязательно для /start и Stars)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Публичный URL игры на Vercel (обязательно для /start)
MINI_APP_URL=https://your-project.vercel.app

# Одноразовый ключ для установки webhook (придумайте сами)
TELEGRAM_WEBHOOK_SETUP_KEY=my_secret_setup_key_123

# Секрет webhook (тот же, что в setWebhook)
TELEGRAM_WEBHOOK_SECRET=random_secret_string

# Supabase (платежи Stars + рейтинг + рынок). Выполните supabase/multiplayer.sql в SQL Editor
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Локальная разработка вне Telegram (только npm run dev)
VITE_STARS_DEV_MOCK=false
